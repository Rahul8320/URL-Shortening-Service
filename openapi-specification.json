{
  "openapi": "3.1.0",
  "info": { "title": "URL Shorten API", "version": "1.0.0" },
  "servers": [{ "url": "http://localhost:5000/trpc" }],
  "paths": {
    "/shorten.createShortenUrl": {
      "post": {
        "operationId": "shorten-createShortenUrl",
        "description": "Create shorten url form long url",
        "tags": ["Shorten"],
        "security": [{ "Authorization": [] }],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Original Long URL"
                  }
                },
                "required": ["url"],
                "additionalProperties": false
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "ID of the shorten url"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri",
                      "description": "Original url"
                    },
                    "shortCode": {
                      "type": "string",
                      "description": "Short code of the shorten url"
                    },
                    "createdAt": {
                      "type": "string",
                      "description": "Creation datetime of the shorten url"
                    },
                    "updatedAt": {
                      "type": "string",
                      "description": "Update datetime of the shorten url"
                    }
                  },
                  "required": [
                    "id",
                    "url",
                    "shortCode",
                    "createdAt",
                    "updatedAt"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "Invalid input data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/error.BAD_REQUEST" }
              }
            }
          },
          "401": {
            "description": "Authorization not provided",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/error.UNAUTHORIZED" }
              }
            }
          },
          "403": {
            "description": "Insufficient access",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/error.FORBIDDEN" }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/error.INTERNAL_SERVER_ERROR"
                }
              }
            }
          }
        }
      }
    },
